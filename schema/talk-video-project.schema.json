{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/YoneRai12/GPURender/schema/talk-video-project.schema.json",
  "title": "Talk Video Project",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "project",
    "timeline",
    "characters",
    "style",
    "sources",
    "renderTargets"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "project": {
      "$ref": "#/$defs/projectMeta"
    },
    "timeline": {
      "$ref": "#/$defs/timeline"
    },
    "characters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/character"
      }
    },
    "style": {
      "$ref": "#/$defs/style"
    },
    "sources": {
      "$ref": "#/$defs/sources"
    },
    "renderTargets": {
      "$ref": "#/$defs/renderTargets"
    },
    "sceneOverrides": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/sceneOverride"
      }
    },
    "lineOverrides": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/lineOverride"
      }
    }
  },
  "$defs": {
    "pathString": {
      "type": "string",
      "minLength": 1
    },
    "projectMeta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "language",
        "description"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "language": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "timeline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fps",
        "width",
        "height",
        "durationFrames",
        "audioMix"
      ],
      "properties": {
        "fps": {
          "type": "integer",
          "minimum": 1
        },
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        },
        "durationFrames": {
          "type": "integer",
          "minimum": 1
        },
        "startTimecode": {
          "type": "string"
        },
        "randomSeed": {
          "type": "integer"
        },
        "colorProfile": {
          "type": "string"
        },
        "audioMix": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "narrationPath"
          ],
          "properties": {
            "narrationPath": {
              "$ref": "#/$defs/pathString"
            },
            "finalMixPath": {
              "$ref": "#/$defs/pathString"
            },
            "bgmPath": {
              "$ref": "#/$defs/pathString"
            }
          }
        }
      }
    },
    "voice": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "speakerName",
        "styleName",
        "speedScale"
      ],
      "properties": {
        "speakerName": {
          "type": "string"
        },
        "styleName": {
          "type": "string"
        },
        "speedScale": {
          "type": "number"
        }
      }
    },
    "visual": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "accent",
        "avatarPath",
        "upperDir"
      ],
      "properties": {
        "accent": {
          "type": "string"
        },
        "accentSoft": {
          "type": "string"
        },
        "avatarPath": {
          "$ref": "#/$defs/pathString"
        },
        "blinkUpperPath": {
          "$ref": "#/$defs/pathString"
        },
        "defaultExpression": {
          "type": "string"
        },
        "upperDir": {
          "$ref": "#/$defs/pathString"
        }
      }
    },
    "character": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "displayName",
        "voice",
        "visual"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "displayName": {
          "type": "string"
        },
        "voice": {
          "$ref": "#/$defs/voice"
        },
        "visual": {
          "$ref": "#/$defs/visual"
        }
      }
    },
    "style": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "layout",
        "subtitleBand"
      ],
      "properties": {
        "layout": {
          "type": "string"
        },
        "subtitleBand": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "alwaysVisible",
            "showSpeakerName"
          ],
          "properties": {
            "alwaysVisible": {
              "type": "boolean"
            },
            "showSpeakerName": {
              "type": "boolean"
            },
            "maxLines": {
              "type": "integer",
              "minimum": 1
            },
            "lineBreakRule": {
              "type": "string"
            },
            "speakerColors": {
              "type": "object",
              "additionalProperties": true
            }
          }
        }
      }
    },
    "sources": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scriptPath"
      ],
      "properties": {
        "scriptPath": {
          "$ref": "#/$defs/pathString"
        },
        "cueDataPath": {
          "$ref": "#/$defs/pathString"
        },
        "mouthDataPath": {
          "$ref": "#/$defs/pathString"
        }
      }
    },
    "sceneOverride": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cueIndex",
        "template"
      ],
      "properties": {
        "cueIndex": {
          "type": "integer",
          "minimum": 1
        },
        "template": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "lineOverride": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cueIndex"
      ],
      "properties": {
        "cueIndex": {
          "type": "integer",
          "minimum": 1
        },
        "text": {
          "type": "string"
        },
        "speedScale": {
          "type": "number"
        }
      }
    },
    "renderTargets": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "remotion",
        "resolve",
        "gpu"
      ],
      "properties": {
        "remotion": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "compositionId"
          ],
          "properties": {
            "compositionId": {
              "type": "string"
            },
            "outputPath": {
              "$ref": "#/$defs/pathString"
            }
          }
        },
        "resolve": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "timelineFormatPreference"
          ],
          "properties": {
            "timelineFormatPreference": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "otio",
                  "fcpxml"
                ]
              }
            },
            "outputPath": {
              "$ref": "#/$defs/pathString"
            }
          }
        },
        "gpu": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "sceneTemplate"
          ],
          "properties": {
            "sceneTemplate": {
              "type": "string"
            },
            "outputPath": {
              "$ref": "#/$defs/pathString"
            }
          }
        }
      }
    }
  }
}
